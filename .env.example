# ResumeForge Environment Variables
# Copy this to .env and fill in your actual values

# ─── Flask Configuration ──────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
# Generate secure key: python -c "import secrets; print(secrets.token_hex(32))"

# ─── Database ────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///instance/resumeforge.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/resumeforge

# ─── File Upload ─────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760  # 10 MB in bytes

# ─── AI Rewriting ────────────────────────────
# Leave empty/unset to use free Ollama (http://localhost:11434)
# Set to enable Claude-based rewrites
# ANTHROPIC_API_KEY=sk-...your-claude-api-key...

# ─── Email (Optional, for future sign-up notifications) ──
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@gmail.com

